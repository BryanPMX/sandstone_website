# Core listings (Spark)
SPARK_ACCESS_TOKEN=
SPARK_API_TOKEN=
SPARK_API_KEY=
SPARK_API_BASE_URL=https://sparkapi.com
SPARK_API_LISTINGS_PATH=/v1/listings
SPARK_API_MY_LISTINGS_PATH=/v1/my/listings
SPARK_API_RENTAL_LISTINGS_PATH=/v1/listings
SPARK_PAGE_SIZE=27
SPARK_ACTIVE_LISTINGS_FILTER=MlsStatus Eq 'Active'
# Defaults to SPARK_ACTIVE_LISTINGS_FILTER when omitted.
SPARK_MY_LISTINGS_FILTER=
SPARK_RENTAL_LISTINGS_FILTER=
SPARK_TEAM_FILTER=
SPARK_DEBUG_LOOKUPS=

# Frontend integrations
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Captcha
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Lead webhooks
ROLU_WEBHOOK_URL=
ROLU_WEBHOOK_CONTACT_URL=
ROLU_WEBHOOK_SELL_URL=
ROLU_WEBHOOK_RENT_URL=
ROLU_WEBHOOK_JOIN_URL=
ROLU_WEBHOOK_GIVEAWAY_URL=
ROLU_WEBHOOK_LISTING_INQUIRY_URL=

# Optional legacy fallback feed
MSL_FEED_URL=

# Optional canonical URL
NEXT_PUBLIC_SITE_URL=
SITE_URL=

# Optional CMS/admin auth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
CMS_ALLOWED_ORIGIN=
CMS_SUCCESS_REDIRECT=
CMS_OAUTH_SCOPES=repo,user:email
CMS_OAUTH_STATE_SECRET=

# GitHub reviews (for Vercel/production)
GITHUB_BOT_TOKEN=
GITHUB_OWNER=sandstone-group
GITHUB_REPO=sandstone_website
GITHUB_BRANCH=main
